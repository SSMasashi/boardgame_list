# =====================
# Data Access Layer
# =====================
@st.cache_data()
def load_data() -> pd.DataFrame:
    """Google SpreadsheetをCSVとして取得し、型処理済みのDataFrameを返す。"""
    try:
        response = requests.get(CSV_URL, timeout=10)
        response.raise_for_status()
    except requests.RequestException as e:
        st.error(f"CSV取得失敗: {e}")
        return pd.DataFrame()

    content = response.content
    try:
        df = pd.read_csv(io.StringIO(content.decode("utf-8-sig")))
    except UnicodeDecodeError:
        df = pd.read_csv(io.StringIO(content.decode("cp932")))

    if df.empty:
        return df

    for c in BOOL_COLS:
        if c in df.columns:
            df[c] = df[c].astype(bool)

    for c in INT_COLS:
        if c in df.columns:
            df[c] = pd.to_numeric(df[c], errors="coerce").fillna(0).astype(int)

    df.setdefault("comment", "")
    df.setdefault("rating", "")
    df["comment"] = df["comment"].fillna("").astype(str)
    df["rating"]  = df["rating"].fillna("").astype(str)

    return df


def save_data(df: pd.DataFrame) -> None:
    """DataFrameをGoogle Spreadsheetへ書き戻す。多重実行を防ぐガード付き。"""
    if st.session_state.get("saving", False):
        return
    st.session_state.saving = True
    try:
        scope = [
            "https://www.googleapis.com/auth/spreadsheets",
            "https://www.googleapis.com/auth/drive",
        ]
        creds = Credentials.from_service_account_info(
            st.secrets["gcp_service_account"], scopes=scope
        )
        client  = gspread.authorize(creds)
        ws      = client.open_by_key(SHEET_KEY).sheet1
        ws.clear()
        ws.resize(len(df) + 1)
        data = [df.columns.tolist()] + df.values.tolist()
        try:
            ws.update(values=data, range_name="A1")
        except TypeError:
            ws.update(data)
        st.toast("保存しました ✓")
    except Exception as e:
        st.error(f"保存失敗: {e}")
    finally:
        st.session_state.saving = False


# =====================
# Formatters
# =====================
def _range_text(a: int, b: int, unit: str) -> str:
    return f"{a}{unit}" if a == b else f"{a}〜{b}{unit}"


def format_players(row: pd.Series) -> str:
    try:
        return _range_text(int(row["min_p"]), int(row["max_p"]), "人")
    except (ValueError, KeyError):
        return ""


def format_time(row: pd.Series) -> str:
    try:
        return _range_text(int(row["min_t"]), int(row["max_t"]), "分")
    except (ValueError, KeyError):
        return ""


# =====================
# Session-state helpers
# =====================
def _init_genre_state(genres: list[str]) -> None:
    """ジャンル選択セッションステートを初期化・同期する。"""
    st.session_state.setdefault("genre_selected", {})
    for g in genres:
        st.session_state.genre_selected.setdefault(g, False)
    for g in list(st.session_state.genre_selected):
        if g not in genres:
            del st.session_state.genre_selected[g]


